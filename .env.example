# ============================================
# OpenModels Environment Configuration
# ============================================

# Database
DATABASE_URL="postgresql://user:password@localhost:5432/openmodels?schema=public"

# JWT Authentication
JWT_SECRET="your-jwt-secret-key-min-32-chars-long"
JWT_REFRESH_SECRET="your-jwt-refresh-secret-key-min-32-chars"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# Google OAuth
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-google-client-secret"
GOOGLE_CALLBACK_URL="http://localhost:3001/api/auth/google/callback"

# Session
SESSION_SECRET="your-session-secret-key"

# Encryption (for API key storage)
ENCRYPTION_KEY="your-32-byte-hex-encryption-key-here"

# Server
PORT=3001
NODE_ENV=development
CLIENT_URL="http://localhost:5173"

# ============================================
# AI Provider API Keys (Platform-level defaults)
# Users can also provide their own keys
# ============================================

# NVIDIA NIM
NVIDIA_API_KEY="nvapi-your-nvidia-api-key"

# Groq
GROQ_API_KEY="gsk_your-groq-api-key"

# OpenRouter
OPENROUTER_API_KEY="sk-or-your-openrouter-api-key"

# Together AI
TOGETHER_API_KEY="your-together-api-key"

# Mistral AI
MISTRAL_API_KEY="your-mistral-api-key"

# Github Models
GITHUB_API_KEY="your-github-token"

# Cerebras
CEREBRAS_API_KEY="your-cerebras-api-key"

# SambaNova
SAMBANOVA_API_KEY="your-sambanova-api-key"

# HuggingFace
HUGGINGFACE_API_KEY="your-huggingface-token"

# OpenCode Zen
OPENCODE_API_KEY="your-opencode-zen-key"

# Cohere
COHERE_API_KEY="your-cohere-key"

# Cloudflare Workers AI
CLOUDFLARE_ACCOUNT_ID="your-cloudflare-account-id"
CLOUDFLARE_API_TOKEN="your-cloudflare-api-token"

# Z.AI
ZAI_API_KEY="3ab7ca88af0a46e4b2d33d8a0afe71c6.EmlZKqQ06z9VNDLn"

# Agens AI
AGNES_API_KEY="your-agens-ai-api-key"

# ============================================
# Web Search Provider API Keys
# ============================================

# Firecrawl (for AI-powered web search + scraping)
FIRECRAWL_API_KEY="fc-your-firecrawl-api-key"
